#!/bin/bash

#SBATCH --job-name PCA_fullCF
#SBATCH --nodes 1
#SBATCH --ntasks-per-node 1
#SBATCH --cpus-per-task 4
#SBATCH --time=3-00:00:00
#SBATCH --output model.out
#SBATCH --account=PHPH039284
#SBATCH --partition=short
#SBATCH --array 1-4
module load languages/julia/1.10.3
echo Running on host `hostname`
echo Time is `date`
echo Directory is `pwd`
echo Slurm job ID is $SLURM_JOB_ID
echo This job runs on the following machines:
echo `echo $SLURM_JOB_NODELIST | uniq`
OMP_DISPLAY_ENV=true
# Run the executable
julia --threads 4 --depwarn=error modelNoLKJ.jl ${SLURM_ARRAY_TASK_ID} > model-${SLURM_ARRAY_TASK_ID}.out
