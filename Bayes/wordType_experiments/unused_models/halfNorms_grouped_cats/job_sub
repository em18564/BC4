#!/bin/bash

#SBATCH --job-name h_g_c
#SBATCH --nodes 1
#SBATCH --ntasks-per-node 1
#SBATCH --cpus-per-task 4
#SBATCH --time=3-00:00:00
#SBATCH --output model.out
#SBATCH --account=PHPH039284
#SBATCH --partition=short
#SBATCH --array 1-4
export NUM_PARTICIPANTS=23
export NUM_WORDS=1931
export TYPE_STRUCTURE="FullCF"

module add languages/julia/1.10.3
echo Running on host `hostname`
echo Time is `date`
echo Directory is `pwd`
echo Slurm job ID is $SLURM_JOB_ID
echo This job runs on the following machines:
echo `echo $SLURM_JOB_NODELIST | uniq`
OMP_DISPLAY_ENV=true
# Run the executable
mkdir -p output
julia --threads 4 model.jl ${SLURM_ARRAY_TASK_ID} ${NUM_PARTICIPANTS} ${NUM_WORDS} ${TYPE_STRUCTURE} > output/model-${SLURM_ARRAY_TASK_ID}.out
